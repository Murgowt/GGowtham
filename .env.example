# App security
APP_PIN=1234
SECRET_KEY=change-me-to-a-long-random-string
PRODUCTION=false

# Public URL of your app (for SnapTrade redirect after connecting Robinhood)
APP_BASE_URL=http://localhost:8000

# SnapTrade (from dashboard.snaptrade.com)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# Optional — auto-created on first connect if empty
SNAPTRADE_USER_ID=
SNAPTRADE_USER_SECRET=

# Dev mode — sample holdings without SnapTrade connection
MOCK_INTEGRATIONS=true

# Database
DATABASE_URL=sqlite:///./brain.db

# Push notifications (generate with: python -m py_vapid --applicationServerKey)
NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
